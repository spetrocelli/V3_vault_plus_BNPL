# ---- Credenziali PayPal Sandbox ----
# Incolla qui Client ID e Secret della tua app Sandbox (developer.paypal.com)
PAYPAL_CLIENT_ID=INCOLLA_QUI_IL_CLIENT_ID
PAYPAL_SECRET=INCOLLA_QUI_IL_SECRET

# Ambiente PayPal: "sandbox" oppure "live"
PAYPAL_ENV=sandbox

# ---- Parametri commerciali della demo (in centesimi NON usati: valori in EUR) ----
CURRENCY=EUR
FULL_PRICE=500.00        # Premio pieno (Scenario A)
DISCOUNT=100.00          # Sconto legato all'installazione black box
DISCOUNTED_PRICE=400.00  # Premio scontato (Scenario B)
EXTRA_AMOUNT=100.00      # Importo extra da stornare/addebitare (= sconto)

# ---- Server ----
PORT=3000

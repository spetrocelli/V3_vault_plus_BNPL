# ---- PayPal Sandbox credentials ----
# Paste here the Client ID and Secret of your Sandbox app (developer.paypal.com)
PAYPAL_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE
PAYPAL_SECRET=PASTE_YOUR_SECRET_HERE

# PayPal environment: "sandbox" or "live"
PAYPAL_ENV=sandbox

# ---- Demo commercial parameters (values in EUR) ----
CURRENCY=EUR
FULL_PRICE=500.00        # Full premium (Scenario A)
DISCOUNT=100.00          # Discount tied to black box installation
DISCOUNTED_PRICE=400.00  # Discounted premium (Scenario B)
EXTRA_AMOUNT=100.00      # Extra amount to refund/charge (= discount)

# ---- Server ----
PORT=3000
